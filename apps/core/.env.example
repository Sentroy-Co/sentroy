# =============================================================================
# Sentroy core (sentroy.com) — environment example  ·  Fair Source (FSL-1.1-ALv2)
# =============================================================================
# Copy to `.env` and fill in. NEVER commit real secrets. Placeholders below are
# safe examples. If you'd rather not self-host, hosted plans are at sentroy.com.
#
# Generate a secret:  openssl rand -base64 32
# =============================================================================

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# Include an explicit db path (…/sentroy) AND set MONGODB_DATABASE to the SAME
# name so the setup seed and import resolve one database.
MONGODB_URI=mongodb://mongo:27017/sentroy
MONGODB_DATABASE=sentroy

# ── Auth core (REQUIRED) ─────────────────────────────────────────────────────
BETTER_AUTH_SECRET=changeme-openssl-rand-base64-32
BETTER_AUTH_URL=https://your-domain.example.com
# Cross-subdomain cookie so *.your-domain share one session. Leave EMPTY for
# localhost / single-host dev.  Prod example: .your-domain.example.com
AUTH_COOKIE_DOMAIN=
# Comma-separated trusted origins for credentialed auth (better-auth).
AUTH_TRUSTED_ORIGINS=https://your-domain.example.com

# ── Domain portability (Phase 3) ─────────────────────────────────────────────
# The single knob that moves the whole platform to your domain. Default
# sentroy.com. Set BOTH (server + client build-time).
SENTROY_ROOT_DOMAIN=your-domain.example.com
NEXT_PUBLIC_ROOT_DOMAIN=your-domain.example.com

# ── Email verification (Phase 4) ─────────────────────────────────────────────
# Unset/"true" → verification required (needs a working mail sender). Set to
# "false" to run signup/login WITHOUT the mail stack (self-host mail-free path).
REQUIRE_EMAIL_VERIFICATION=false
# Optional plain-SMTP fallback sender (only used when SMTP_HOST is set AND the
# Sentroy mail platform is not provisioned). Lets a mail-free instance still
# deliver verification / password-reset mail via any mailbox.
# NOTE: enabling this requires the `nodemailer` dependency (see docs).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── First-run setup wizard ───────────────────────────────────────────────────
# The /setup wizard seeds the first admin. adminEmail is REQUIRED (no default).
ADMIN_EMAIL=you@your-domain.example.com
ADMIN_PASSWORD=changeme-strong-password
# Optional token gating the setup endpoints (recommended on a public IP).
SETUP_TOKEN=

# ── Encryption / internal (REQUIRED) ─────────────────────────────────────────
# Env Vault master key — encrypts secrets at rest. Same value across every app
# sharing this DB. LOSS = unrecoverable ciphertext; back it up securely.
SENTROY_ENV_MASTER_KEY=changeme-openssl-rand-base64-32
# Shared secret for server-to-server (core ↔ mail/storage) calls.
INTERNAL_API_SECRET=changeme-openssl-rand-base64-32

# ── CDN / storage link (PRODUCT-CONDITIONAL: storage product) ────────────────
# Internal URL when cdn runs in the same compose; secret shared with cdn.
CDN_API_URL=http://cdn:4100
CDN_API_SECRET=changeme-openssl-rand-base64-32

# ── Cross-app URLs (OPTIONAL — default derived from ROOT_DOMAIN) ──────────────
# Per-app overrides; unset → https://<sub>.<ROOT_DOMAIN>. Set for a split deploy.
NEXT_PUBLIC_CORE_APP_URL=
NEXT_PUBLIC_MAIL_APP_URL=
NEXT_PUBLIC_STORAGE_APP_URL=
NEXT_PUBLIC_VAULT_APP_URL=
NEXT_PUBLIC_AUTH_APP_URL=
NEXT_PUBLIC_STATUS_APP_URL=
NEXT_PUBLIC_STUDIO_APP_URL=
NEXT_PUBLIC_WHATSAPP_APP_URL=
NEXT_PUBLIC_LINEAR_APP_URL=
NEXT_PUBLIC_OPENCUT_APP_URL=
NEXT_PUBLIC_MEET_APP_URL=
NEXT_PUBLIC_TOOLS_APP_URL=
NEXT_PUBLIC_BACKUP_APP_URL=
NEXT_PUBLIC_SENTROY_API_URL=

# ── OAuth / OIDC signing (OPTIONAL — RS256; HS256 fallback if unset) ─────────
# PEM. 2-slot rotation: copy current → _PREVIOUS, generate new primary.
OAUTH_RSA_PRIVATE_KEY=
OAUTH_RSA_PRIVATE_KEY_PREVIOUS=
OAUTH_ISSUER=

# ── Social login (OPTIONAL — graceful when unset) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Bot protection / geo (OPTIONAL — graceful) ───────────────────────────────
# Turnstile: unset → CAPTCHA disabled everywhere (dev-friendly).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
BETTER_AUTH_TURNSTILE_SECRET=
TURNSTILE_DISABLED=1
NEXT_PUBLIC_TURNSTILE_DISABLED=1
IPINFO_TOKEN=

# ── AI assistant (OPTIONAL — null when unset) ────────────────────────────────
AI_GATEWAY_API_KEY=

# ── App Store registry (Phase 5 — OPTIONAL, OFF by default) ──────────────────
# Instance-side sync: pull Sentroy's Ed25519-signed global app catalog and merge
# it locally (WordPress.org model). Your own local/company apps are untouched.
APP_REGISTRY_ENABLED=
APP_REGISTRY_URL=https://sentroy.com
# Pinned verification key(s); unset → the baked Sentroy public key. Override for
# forks/rotation.
APP_REGISTRY_PUBLIC_KEY=
APP_REGISTRY_PUBLIC_KEY_PREVIOUS=
APP_REGISTRY_SYNC_INTERVAL=21600
APP_REGISTRY_TELEMETRY=
# Server-side ONLY (the registry HOST, i.e. sentroy.com): Ed25519 signing key +
# catalog TTL. Presence activates the /api/public/app-registry export API.
# Leave UNSET on a normal self-host instance (it is a consumer, not a host).
APP_REGISTRY_PRIVATE_KEY=
APP_REGISTRY_CATALOG_TTL=86400

# OS App Store embed CSP guard. In production NODE_ENV it is always on; on a
# self-host running a non-production NODE_ENV set SENTROY_EMBED_CSP=1 to force it.
SENTROY_EMBED_CSP=

# ── Misc / optional integrations ─────────────────────────────────────────────
SENTROY_ADMIN_API_KEY=
BETTER_AUTH_API_KEY=
DOMAIN=your-domain.example.com
# Domain Connect signed-sync (OPTIONAL — DNS onboarding for Cloudflare etc.)
DOMAIN_CONNECT_PRIVATE_KEY=
DOMAIN_CONNECT_PRIVATE_KEY_B64=
DOMAIN_CONNECT_KEY_ID=
