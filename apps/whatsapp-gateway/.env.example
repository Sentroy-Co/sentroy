# =============================================================================
# whatsapp-gateway — environment example
#
# LICENSING NOTE: This directory (apps/whatsapp-gateway/) is licensed
# GPL-3.0-or-later because it links the Baileys WhatsApp library. It is a
# CARVE-OUT from the rest of this repository, which is Fair Source
# (root LICENSE = FSL-1.1-ALv2, converting to Apache-2.0 after two years).
# See ./LICENSING.md and ./LICENSE. This is source-available software, not
# "open source". The Sentroy name and logos are excluded (see TRADEMARK.md).
#
# Prefer not to self-host? Hosted plans are available at sentroy.com.
#
# Copy this file to .env and fill in the values below.
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Optional — HTTP port the gateway listens on. Default: 4200.
PORT=4200


# -----------------------------------------------------------------------------
# Encryption (REQUIRED)
#
# WhatsApp session credentials are stored encrypted at rest (AES-256-GCM).
# The gateway resolves the master key from the first set of:
#   WHATSAPP_ENC_KEY  ->  SENTROY_ENV_MASTER_KEY  ->  STATUS_ENV_MASTER_KEY
# If NONE are set, the process THROWS on first credential access and refuses
# to store WhatsApp credentials unencrypted (see src/crypto.ts).
#
# Generate a key with:  openssl rand -base64 32
# -----------------------------------------------------------------------------

# Optional — gateway-specific override key. If set, takes precedence.
WHATSAPP_ENC_KEY=

# Required (unless WHATSAPP_ENC_KEY is set) — the platform-wide master key.
# The same value must match the rest of the Sentroy deployment.
SENTROY_ENV_MASTER_KEY=changeme-openssl-rand-base64-32

# Optional — legacy fallback key (last-resort). Leave empty in new deployments.
STATUS_ENV_MASTER_KEY=


# -----------------------------------------------------------------------------
# Internal auth (server-to-server)
# -----------------------------------------------------------------------------

# Required — shared secret verified on the `x-internal-secret` header for all
# server-to-server calls from the whatsapp app. Must match the caller's value.
# Generate with:  openssl rand -base64 32
INTERNAL_API_SECRET=changeme-openssl-rand-base64-32


# -----------------------------------------------------------------------------
# Database (REQUIRED — from @workspace/db)
# -----------------------------------------------------------------------------

# Required — MongoDB connection string.
MONGODB_URI=mongodb://localhost:27017

# Optional — database name. Falls back to the DB library default when unset.
MONGODB_DATABASE=


# -----------------------------------------------------------------------------
# Root domain / portability (from @workspace/db -> packages/auth domains.ts)
#
# A single root-domain pair drives all cross-subdomain hosts/CORS/CSP.
# Default: sentroy.com. Change both together when self-hosting on your domain.
# -----------------------------------------------------------------------------

# Optional (graceful) — server-side root domain. Default: sentroy.com.
SENTROY_ROOT_DOMAIN=sentroy.com

# Optional (graceful) — client-side root domain. Default: sentroy.com.
NEXT_PUBLIC_ROOT_DOMAIN=sentroy.com


# -----------------------------------------------------------------------------
# Send pacing / anti-ban tuning (all optional — graceful defaults)
# -----------------------------------------------------------------------------

# Optional — minimum gap between outgoing messages, in ms. Default: 1200.
WHATSAPP_SEND_MIN_GAP_MS=1200

# Optional — added random jitter on top of the min gap, in ms. Default: 800.
WHATSAPP_SEND_JITTER_MS=800

# Optional — pino log level (trace|debug|info|warn|error). Default: warn.
WHATSAPP_LOG_LEVEL=warn
