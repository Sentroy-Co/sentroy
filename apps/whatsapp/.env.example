# =============================================================================
# Sentroy whatsapp (whatsapp.sentroy.com, port 3007) — env example · Fair Source
# =============================================================================
# Dashboard app; pairs with the whatsapp-gateway service (Baileys, GPL-3.0).

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/sentroy
MONGODB_DATABASE=sentroy

# ── Cross-app / auth (REQUIRED) ──────────────────────────────────────────────
AUTH_COOKIE_DOMAIN=
SENTROY_ENV_MASTER_KEY=changeme-openssl-rand-base64-32
INTERNAL_API_SECRET=changeme-openssl-rand-base64-32
SENTROY_ROOT_DOMAIN=your-domain.example.com
NEXT_PUBLIC_ROOT_DOMAIN=your-domain.example.com
NEXT_PUBLIC_CORE_APP_URL=
NEXT_PUBLIC_WHATSAPP_APP_URL=

# ── Gateway link (REQUIRED) ──────────────────────────────────────────────────
# Internal URL + shared secret of the whatsapp-gateway service.
WHATSAPP_GATEWAY_URL=http://whatsapp-gateway:4200
WHATSAPP_GATEWAY_SECRET=changeme
