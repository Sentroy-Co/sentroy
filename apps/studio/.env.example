# ============================================================================
# Sentroy Studio (apps/studio) — environment example
# ----------------------------------------------------------------------------
# Sentroy is FAIR SOURCE, not open source. The root LICENSE is FSL-1.1-ALv2
# (Functional Source License; converts to Apache-2.0 two years after release).
# apps/whatsapp-gateway/ is GPL-3.0-or-later; packages/app-manifest/ is MIT.
# The Sentroy name and logos are excluded by TRADEMARK.md.
#
# Prefer not to self-host? Buy a hosted plan at sentroy.com.
#
# Copy this file to `.env` and fill in the values. Studio runs on port 3006.
# NEVER commit real secrets. Placeholders below are safe examples only.
# ============================================================================

# ----------------------------------------------------------------------------
# Core / runtime
# ----------------------------------------------------------------------------
# Optional — HTTP port for this app. Default: 3006.
PORT=3006
# Optional — build/runtime environment. Usually "development" or "production".
NODE_ENV=development
# Optional — surfaced as the running app version string.
APP_VERSION=0.0.0

# ----------------------------------------------------------------------------
# Database (REQUIRED)
# ----------------------------------------------------------------------------
# Required — MongoDB connection string. The app will not start without it.
MONGODB_URI=mongodb://localhost:27017
# Optional — database name to use within the connection.
MONGODB_DATABASE=sentroy

# ----------------------------------------------------------------------------
# Secrets (REQUIRED)
# ----------------------------------------------------------------------------
# Required — master key that decrypts stored env/secret values.
# Generate with: openssl rand -base64 32
SENTROY_ENV_MASTER_KEY=changeme-run-openssl-rand-base64-32
# Required — shared secret for server-to-server (internal) API calls between apps.
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=changeme-run-openssl-rand-base64-32
# Required — better-auth signing secret for sessions.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=changeme-run-openssl-rand-base64-32

# ----------------------------------------------------------------------------
# Portability — root domain (drives all cross-subdomain hosts / CORS / CSP)
# ----------------------------------------------------------------------------
# Optional (graceful) — single knob for all cross-subdomain hosts. Default: sentroy.com.
SENTROY_ROOT_DOMAIN=sentroy.com
# Optional (graceful) — client-visible mirror of the root domain. Default: sentroy.com.
NEXT_PUBLIC_ROOT_DOMAIN=sentroy.com

# ----------------------------------------------------------------------------
# Auth / session
# ----------------------------------------------------------------------------
# Optional (graceful) — cookie domain for cross-subdomain SSO, e.g. .example.com.
AUTH_COOKIE_DOMAIN=
# Optional (graceful) — comma-separated extra trusted origins for auth.
AUTH_TRUSTED_ORIGINS=
# Optional — public base URL of this app used by better-auth.
BETTER_AUTH_URL=https://studio.example.com
# Optional (graceful) — set false to run signup/login WITHOUT the mail stack.
REQUIRE_EMAIL_VERIFICATION=false

# Optional (graceful) — Google OAuth social login. Skipped when unset.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional (graceful) — GitHub OAuth social login. Skipped when unset.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# Cross-app service URLs (server-side)
# ----------------------------------------------------------------------------
# Optional (graceful) — internal/public URLs of sibling apps. Fall back to
# NEXT_PUBLIC_* equivalents when unset.
CORE_APP_URL=https://studio.example.com
MAIL_APP_URL=https://mail.example.com
STORAGE_APP_URL=https://storage.example.com

# ----------------------------------------------------------------------------
# Cross-app service URLs (public / client-visible)
# ----------------------------------------------------------------------------
# Optional (graceful) — browser-facing URLs of sibling apps.
NEXT_PUBLIC_CORE_APP_URL=https://sentroy.example.com
NEXT_PUBLIC_MAIL_APP_URL=https://mail.example.com
NEXT_PUBLIC_STORAGE_APP_URL=https://storage.example.com
NEXT_PUBLIC_AUTH_URL=https://auth.example.com
NEXT_PUBLIC_STATUS_APP_URL=https://status.example.com
NEXT_PUBLIC_STUDIO_APP_URL=https://studio.example.com
NEXT_PUBLIC_VAULT_APP_URL=https://vault.example.com

# ----------------------------------------------------------------------------
# CDN / media (PRODUCT-CONDITIONAL — required only when using S3-backed media)
# ----------------------------------------------------------------------------
# Optional (graceful) — CDN service base URL for uploads/streaming.
CDN_API_URL=https://cdn.example.com
# Optional (graceful) — shared secret for authenticated CDN admin calls.
CDN_API_SECRET=changeme
# Optional (graceful) — public CDN base URL used by the browser.
NEXT_PUBLIC_CDN_URL=https://cdn.example.com

# ----------------------------------------------------------------------------
# Env Vault integration
# ----------------------------------------------------------------------------
# Optional (graceful) — Sentroy env/secret vault service URL + API key.
SENTROY_ENV_API_URL=
SENTROY_ENV_API_KEY=
# Optional (graceful) — client-visible vault API key.
NEXT_PUBLIC_SENTROY_ENV_API_KEY=
# Optional (graceful) — secret used to verify inbound vault webhooks.
SENTROY_VAULT_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Miscellaneous (all optional / graceful)
# ----------------------------------------------------------------------------
# Optional (graceful) — set to disable Cloudflare Turnstile challenge checks.
TURNSTILE_DISABLED=
# Optional — default locale for system emails (e.g. en, tr).
SYSTEM_MAIL_DEFAULT_LOCALE=en

# ----------------------------------------------------------------------------
# App Store registry (Phase 5, optional)
# ----------------------------------------------------------------------------
# Optional — set to 1 to pull Sentroy's Ed25519-signed global app catalog and
# merge it locally (WordPress.org model). Verification uses a public key pinned
# in code; your own local/company apps are untouched. Sentroy curates the
# global catalog centrally. Leave unset to run with local apps only.
APP_REGISTRY_ENABLED=
