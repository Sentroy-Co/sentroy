# ============================================================================
# Sentroy Backup app (apps/backup) — example environment
# ----------------------------------------------------------------------------
# Sentroy is FAIR SOURCE (source-available), NOT open source.
#   Root LICENSE = FSL-1.1-ALv2 (converts to Apache-2.0 after 2 years).
#   apps/whatsapp-gateway/ = GPL-3.0-or-later. packages/app-manifest/ = MIT.
#   The Sentroy name/logos are excluded (see TRADEMARK.md).
# Don't want to self-host? Buy a hosted plan at sentroy.com.
#
# NEVER commit real secret values. Copy this file to `.env` and fill it in.
# This app runs on port 3010 (backup.<root-domain>). Its worker runs alongside.
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED — Database (MongoDB)
# ----------------------------------------------------------------------------
# required: MongoDB connection string for the shared Sentroy database.
MONGODB_URI=mongodb://localhost:27017

# optional: database name (falls back to the DB embedded in MONGODB_URI).
MONGODB_DATABASE=sentroy

# ----------------------------------------------------------------------------
# REQUIRED — Secrets
# ----------------------------------------------------------------------------
# required: master key used to encrypt stored MongoDB connection URIs at rest.
# Generate with: openssl rand -base64 32
SENTROY_ENV_MASTER_KEY=changeme-run-openssl-rand-base64-32

# required (server-to-server): shared secret between the backup app and its worker,
# and for core <-> backup internal calls. Generate with: openssl rand -base64 32
BACKUP_API_SECRET=changeme-run-openssl-rand-base64-32

# required (server-to-server): shared internal secret used across Sentroy apps
# (core <-> mail/storage/backup). Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=changeme-run-openssl-rand-base64-32

# ----------------------------------------------------------------------------
# REQUIRED — Auth / session cookie
# ----------------------------------------------------------------------------
# required: cross-subdomain cookie domain so all Sentroy apps share one session.
# Use a leading dot for subdomain sharing (e.g. .example.com). For pure localhost
# dev this can be left unset.
AUTH_COOKIE_DOMAIN=.example.com

# optional: comma-separated list of extra trusted origins for auth (CORS/CSRF).
AUTH_TRUSTED_ORIGINS=

# optional (graceful): when false, signup/login run WITHOUT the mail stack
# (no email verification). Set to true only if the mail product is configured.
REQUIRE_EMAIL_VERIFICATION=false

# ----------------------------------------------------------------------------
# Portability — root domain (drives all cross-subdomain hosts/CORS/CSP)
# ----------------------------------------------------------------------------
# optional: single source of truth for the platform root domain (server side).
# Defaults to sentroy.com when unset.
SENTROY_ROOT_DOMAIN=example.com

# optional: same root domain exposed to the browser. Defaults to sentroy.com.
NEXT_PUBLIC_ROOT_DOMAIN=example.com

# ----------------------------------------------------------------------------
# Service URLs (server-to-server + client)
# ----------------------------------------------------------------------------
# optional: URL of the backup worker the app dispatches restore/backup jobs to.
BACKUP_WORKER_URL=http://localhost:3010

# optional: URL of the core app for internal calls / session validation.
CORE_APP_URL=https://core.example.com

# optional: public URL of this backup app (browser-visible).
NEXT_PUBLIC_BACKUP_APP_URL=https://backup.example.com

# optional: public URL of the backup worker (browser-visible).
NEXT_PUBLIC_BACKUP_WORKER_URL=https://backup.example.com

# optional: public URL of the core app (browser-visible).
NEXT_PUBLIC_CORE_APP_URL=https://core.example.com

# ----------------------------------------------------------------------------
# Runtime metadata (usually set automatically)
# ----------------------------------------------------------------------------
# optional: app version string, injected at build/deploy time.
APP_VERSION=0.0.0

# optional: Node environment. Next.js sets this automatically (development/production).
NODE_ENV=development
