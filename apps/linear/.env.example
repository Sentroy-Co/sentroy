# apps/linear — Linear Lite (linear.sentroy.com, port 3009)
# Whatsapp app deseniyle aynı auth kurulumu: better-auth cross-subdomain
# session + core rewrite'ları. Kopyala → .env doldur.

# --- MongoDB ---------------------------------------------------------------
# Prod runtime: internal Docker alias (mongo:27017). Lokal dev: SSH tünel ile
# 127.0.0.1:27017 (bkz. root README §5.10).
MONGODB_URI=mongodb://127.0.0.1:27017/sentroy
# Opsiyonel: URI'de db adı yoksa
# MONGODB_DATABASE=sentroy

# --- better-auth (cross-subdomain session) ----------------------------------
# Core ile AYNI secret olmalı — session cookie'si .sentroy.com'a yazılır.
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=https://sentroy.com
# Prod: .sentroy.com ; lokal dev'de boş bırak (port bazlı cookie).
AUTH_COOKIE_DOMAIN=.sentroy.com
AUTH_TRUSTED_ORIGINS=https://sentroy.com,https://linear.sentroy.com

# --- Cross-app URL'ler -------------------------------------------------------
# Auth + company + avatar rewrite hedefi (server-side; Docker'da internal URL).
CORE_APP_URL=http://localhost:3000
# Login redirect'lerinde kullanılan public core URL'i (build-time'da gömülür).
NEXT_PUBLIC_CORE_APP_URL=http://localhost:3000
# Bu app'in public URL'i — proxy login callbackUrl + launcher linkleri.
NEXT_PUBLIC_LINEAR_APP_URL=https://localhost:3009

# --- Secrets vault -----------------------------------------------------------
# linear_settings'teki API key / webhook secret cipher'ları bu master key ile
# AES-256-GCM. Core'daki SENTROY_ENV_MASTER_KEY ile AYNI değer olmalı.
# Üret: openssl rand -base64 32
SENTROY_ENV_MASTER_KEY=

# Web Push (opsiyonel) — platform-seviye VAPID keypair (linear app). Tanımlı
# değilse push devre dışı; açık sekme SSE bildirimleri etkilenmez.
# `npx web-push generate-vapid-keys` ile üret.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@sentroy.com
