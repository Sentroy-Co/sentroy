PORT=4100
# The CDN's public origin. Every URL handed back to consumers is built from
# this — set it to whatever domain sits in front of the service.
BASE_URL=https://cdn.example.com

# CDN-owned MongoDB. Don't share this with the consuming app's DB; the CDN
# is the source of truth for media records and doesn't want noisy neighbors.
MONGODB_URI=mongodb://localhost:27017/cdn

IDRIVE_ENDPOINT=https://endpoint.idrivee2.com
IDRIVE_ACCESS_KEY=
IDRIVE_SECRET_KEY=
IDRIVE_BUCKET=
IDRIVE_REGION=eu-central-2

# Shared secret required on every /cdn/* request (upload/list/delete).
CDN_API_SECRET=your-shared-secret-here

# Optional system-status watchdog. When configured, the CDN process calls Core's
# system-status endpoint after boot and then every 30 minutes so probes are
# recorded even when the admin page is closed.
CORE_APP_URL=https://sentroy.com
INTERNAL_API_SECRET=your-internal-secret-here
SYSTEM_STATUS_WATCHDOG_INTERVAL_MS=1800000
SYSTEM_STATUS_WATCHDOG_INITIAL_DELAY_MS=5000
SYSTEM_STATUS_WATCHDOG_TIMEOUT_MS=10000
