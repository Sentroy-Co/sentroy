# =============================================================================
# Sentroy mail (mail.sentroy.com, port 3001) — env example · Fair Source
# =============================================================================
# The mail PRODUCT requires the mail-server compose profile (Postfix/Dovecot/
# Rspamd/PG/Redis/API). Copy to .env; NEVER commit real secrets.

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/sentroy
MONGODB_DATABASE=sentroy

# ── Cross-app / auth (REQUIRED) ──────────────────────────────────────────────
AUTH_COOKIE_DOMAIN=
SENTROY_ENV_MASTER_KEY=changeme-openssl-rand-base64-32
INTERNAL_API_SECRET=changeme-openssl-rand-base64-32
SENTROY_ROOT_DOMAIN=your-domain.example.com
NEXT_PUBLIC_ROOT_DOMAIN=your-domain.example.com
NEXT_PUBLIC_CORE_APP_URL=
NEXT_PUBLIC_MAIL_APP_URL=

# ── Mail-server SDK (REQUIRED for the mail product) ──────────────────────────
# Base URL + API key of the mail-server API service (in the `mail` profile).
MAIL_SERVER_API_URL=http://mail-server-api:3000
MAIL_SERVER_API_KEY=changeme
