# downloader-worker — apps/downloader (Next.js) buraya x-internal-secret ile konuşur.
PORT=4300
DOWNLOADER_API_SECRET=change-me-shared-with-downloader-app

# Geçici indirme dizini + dosya TTL (varsayılan 1 saat). Cleanup 5 dk'da bir tarar.
DOWNLOAD_DIR=/tmp/dl
FILE_TTL_MS=3600000

# yt-dlp ayarları
# YTDLP_BIN=yt-dlp                 # lokal test için path override (örn. /opt/homebrew/bin/yt-dlp)
MAX_FILESIZE=500M
YTDLP_TIMEOUT_MS=300000

# Bot-koruması (opsiyonel) — "Sign in to confirm you're not a bot" hatası gelirse:
# YTDLP_COOKIES_FILE=/secrets/youtube-cookies.txt   # bir YT hesabının cookies.txt'i
# YTDLP_PROXY=http://user:pass@residential-proxy:port
