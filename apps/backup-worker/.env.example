# backup-worker — apps/backup (Next.js) buraya x-internal-secret ile konuşur.
# Public domain YOK; yalnız Docker internal network. mongodump/mongorestore çalıştırır.
PORT=4400

# apps/backup ile paylaşılan internal secret (x-internal-secret header).
BACKUP_API_SECRET=change-me-shared-with-backup-app

# Platform Mongo (job status + connection okuma) — internal alias, public IP DEĞİL.
MONGODB_URI=mongodb://mongo:27017/sentroy
# MONGODB_DATABASE=sentroy   # URI'de db adı yoksa

# Bağlantı URI'lerini decrypt etmek için — core/env-vault ile AYNI master key.
SENTROY_ENV_MASTER_KEY=change-me-same-as-core-env-vault-key

# S3 (iDrive e2 / S3-uyumlu) — yedek artefaktları. storage-api-server ile aynı hesap olabilir,
# ama AYRI bucket önerilir (BACKUP_S3_BUCKET). Artefaktlar PRIVATE.
IDRIVE_ENDPOINT=https://<region>.idrivee2-XX.com
IDRIVE_REGION=us-east-1
IDRIVE_ACCESS_KEY=change-me
IDRIVE_SECRET_KEY=change-me
BACKUP_S3_BUCKET=sentroy-mongo-backups

# Geçici çalışma dizini (şu an stream-only; ileride disk buffer gerekirse).
WORK_DIR=/tmp/backups
