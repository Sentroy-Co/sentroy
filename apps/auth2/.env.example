# =============================================================================
# Sentroy auth2 (auth.sentroy.com) — environment example
# =============================================================================
# App: OAuth 2.0 / OIDC provider + Auth-as-a-Service. Runs on port 3003.
# Copy to .env and fill in values. NEVER commit real secrets.
#
# Sentroy is Fair Source software (see root LICENSE, FSL-1.1-ALv2). If you would
# rather not self-host, hosted plans are available at sentroy.com.
# =============================================================================


# -----------------------------------------------------------------------------
# Core / required
# -----------------------------------------------------------------------------

# REQUIRED — MongoDB connection string (shared platform database).
MONGODB_URI=mongodb://localhost:27017

# OPTIONAL — database name (falls back to the DB in MONGODB_URI if unset).
MONGODB_DATABASE=sentroy

# REQUIRED — master key used to encrypt/decrypt secrets at rest. Generate with:
#   openssl rand -base64 32
# Must be identical across every Sentroy app that shares this database.
SENTROY_ENV_MASTER_KEY=changeme-openssl-rand-base64-32

# REQUIRED — shared secret for server-to-server (internal) API calls between
# Sentroy apps. Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=changeme-openssl-rand-base64-32

# OPTIONAL — Node environment. Usually set by the runtime ("production"/"development").
NODE_ENV=development


# -----------------------------------------------------------------------------
# Cross-subdomain auth (better-auth) session cookie
# -----------------------------------------------------------------------------

# OPTIONAL (graceful) — cookie domain so a single session is shared across all
# *.sentroy.com subdomains. Leave empty for localhost / single-host dev.
# Example (production): .sentroy.com
AUTH_COOKIE_DOMAIN=

# OPTIONAL (graceful) — comma-separated list of trusted origins for auth CORS.
# Defaults are derived from the root domain when unset.
AUTH_TRUSTED_ORIGINS=


# -----------------------------------------------------------------------------
# Domain / portability
# -----------------------------------------------------------------------------
# A single root domain drives every cross-subdomain host, CORS, and CSP rule.
# Default is sentroy.com. Set both (server + client) to self-host on your domain.

# OPTIONAL (graceful) — server-side root domain. Default: sentroy.com
SENTROY_ROOT_DOMAIN=example.com

# OPTIONAL (graceful) — client-side root domain (must match SENTROY_ROOT_DOMAIN).
NEXT_PUBLIC_ROOT_DOMAIN=example.com


# -----------------------------------------------------------------------------
# OAuth / OIDC id_token signing
# -----------------------------------------------------------------------------
# Signing is dual-mode. RS256 is recommended for production (publishes a JWKS
# and supports 2-slot key rotation). HS256 is a fallback for simple setups.

# OPTIONAL (recommended for prod) — RSA private key in PEM format for RS256.
# Generate with: openssl genrsa 2048
# Paste the full PEM (newlines preserved or \n-escaped, depending on your loader).
OAUTH_RSA_PRIVATE_KEY=

# OPTIONAL — previous RSA private key (PEM), kept in the JWKS during rotation so
# tokens signed by the old key still verify. Remove after old tokens expire.
OAUTH_RSA_PRIVATE_KEY_PREVIOUS=

# OPTIONAL (graceful) — HS256 fallback secret (>= 32 chars). Used only when no
# OAUTH_RSA_PRIVATE_KEY is set. Generate with: openssl rand -base64 32
OAUTH_ID_TOKEN_SECRET=

# OPTIONAL (graceful) — OIDC issuer URL advertised in tokens / discovery.
# Defaults to the app's public URL when unset. Example: https://auth.example.com
OAUTH_ISSUER=


# -----------------------------------------------------------------------------
# "Sign in with Sentroy" federation (this app acting as an OAuth client)
# -----------------------------------------------------------------------------

# OPTIONAL (graceful) — client id issued by the upstream Sentroy OAuth provider.
SENTROY_CLIENT_ID=

# OPTIONAL (graceful) — matching client secret. Keep server-only.
SENTROY_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Email verification
# -----------------------------------------------------------------------------

# OPTIONAL (graceful) — when "false", signup/login run WITHOUT the mail stack
# (no verification email is sent). Set "true" only if the mail product is
# configured. Default behavior treats unset as verification-off for self-host.
REQUIRE_EMAIL_VERIFICATION=false


# -----------------------------------------------------------------------------
# Anti-abuse / geo (all optional — features degrade gracefully when unset)
# -----------------------------------------------------------------------------

# OPTIONAL (graceful) — set "true"/"1" to bypass Cloudflare Turnstile in dev.
# Leave unset in production if you have configured Turnstile.
TURNSTILE_DISABLED=

# OPTIONAL (graceful) — IPinfo token for IP geolocation on auth events.
IPINFO_TOKEN=


# -----------------------------------------------------------------------------
# Cross-app public URLs (client-visible, NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
# Used to link/redirect between Sentroy apps. Defaults are derived from the root
# domain; override only for non-standard hosts or local development.

# This app's own public URL (auth.sentroy.com).
NEXT_PUBLIC_AUTH_APP_URL=https://auth.example.com

# core app (sentroy.com, port 3000).
NEXT_PUBLIC_CORE_APP_URL=https://example.com

# mail app (mail.sentroy.com, port 3001).
NEXT_PUBLIC_MAIL_APP_URL=https://mail.example.com

# storage app (storage.sentroy.com, port 3002).
NEXT_PUBLIC_STORAGE_APP_URL=https://storage.example.com

# status page (status.sentroy.com, port 3004).
NEXT_PUBLIC_STATUS_URL=https://status.example.com

# env-vault app.
NEXT_PUBLIC_VAULT_APP_URL=https://vault.example.com

# documentation (docs subpath on core).
NEXT_PUBLIC_DOCS_URL=https://example.com/docs

# public Sentroy API base URL.
NEXT_PUBLIC_SENTROY_API_URL=https://example.com


# -----------------------------------------------------------------------------
# Server-side cross-app URL (internal networking)
# -----------------------------------------------------------------------------

# OPTIONAL (graceful) — server-to-server URL for the core app. Prefer an internal
# hostname in container networks (e.g. http://core:3000); falls back to
# NEXT_PUBLIC_CORE_APP_URL when unset.
CORE_APP_URL=
