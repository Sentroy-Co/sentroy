# =============================================================================
# Sentroy storage (storage.sentroy.com, port 3002) — env example · Fair Source
# =============================================================================
# Requires an S3-compatible object store (via the cdn service) for the storage
# product. Copy to .env; NEVER commit real secrets.

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/sentroy
MONGODB_DATABASE=sentroy

# ── Cross-app / auth (REQUIRED) ──────────────────────────────────────────────
AUTH_COOKIE_DOMAIN=
SENTROY_ENV_MASTER_KEY=changeme-openssl-rand-base64-32
INTERNAL_API_SECRET=changeme-openssl-rand-base64-32
SENTROY_ROOT_DOMAIN=your-domain.example.com
NEXT_PUBLIC_ROOT_DOMAIN=your-domain.example.com
NEXT_PUBLIC_CORE_APP_URL=
NEXT_PUBLIC_STORAGE_APP_URL=

# ── CDN link (REQUIRED) ──────────────────────────────────────────────────────
CDN_API_URL=http://cdn:4100
CDN_API_SECRET=changeme-openssl-rand-base64-32

# ── Object storage — configured on the `cdn` service, shown here for reference ─
# Primary S3_* names (IDRIVE_* still read as a deprecated fallback):
#   S3_ENDPOINT, S3_REGION, S3_ACCESS_KEY, S3_SECRET_KEY, S3_BUCKET
