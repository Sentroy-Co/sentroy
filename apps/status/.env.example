# =============================================================================
# Sentroy Status app (status.sentroy.com, port 3004) — example env
# =============================================================================
# Fair Source software (repo LICENSE: FSL-1.1-ALv2, converts to Apache-2.0
# after 2 years). This is NOT "open source". Prefer a hosted plan instead of
# self-hosting? Hosted plans are available at sentroy.com.
#
# Copy to .env and fill in. NEVER commit real secrets. Placeholder values below
# are safe defaults / hints only.
# =============================================================================

# -----------------------------------------------------------------------------
# Core / required
# -----------------------------------------------------------------------------

# REQUIRED — MongoDB connection string (shared platform database).
MONGODB_URI=mongodb://localhost:27017

# OPTIONAL — Mongo database name (falls back to the DB in the URI / default).
MONGODB_DATABASE=sentroy

# REQUIRED — master key used to encrypt/decrypt stored env/secret material
# (from @workspace/auth). Generate with: openssl rand -base64 32
SENTROY_ENV_MASTER_KEY=changeme-openssl-rand-base64-32

# NOTE on STATUS_ENV_MASTER_KEY:
# The status app / status-worker probe scheduler reads encrypted probe config
# using the SAME master key as core. In deployment this is wired as
# STATUS_ENV_MASTER_KEY and MUST equal core's SENTROY_ENV_MASTER_KEY. If your
# platform uses a single key everywhere, set both to the same value.
STATUS_ENV_MASTER_KEY=changeme-same-as-core-SENTROY_ENV_MASTER_KEY

# REQUIRED for server-to-server calls (core <-> status/mail/storage probes).
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=changeme-openssl-rand-base64-32

# -----------------------------------------------------------------------------
# Auth / session (from @workspace/auth) — cross-subdomain cookie sharing
# -----------------------------------------------------------------------------

# OPTIONAL — parent domain for the shared session cookie. Set in production so
# all *.<root> apps see one session. Leave empty for local dev (per-port).
AUTH_COOKIE_DOMAIN=

# OPTIONAL — comma-separated list of trusted origins for auth (CORS/redirects).
AUTH_TRUSTED_ORIGINS=

# OPTIONAL — single-source cross-subdomain root domain (server side). Drives
# hosts/CORS/CSP across apps. Default: sentroy.com
SENTROY_ROOT_DOMAIN=sentroy.com

# -----------------------------------------------------------------------------
# Cross-app service URLs (server-to-server; used for status probes)
# -----------------------------------------------------------------------------

# OPTIONAL — internal/public URLs of sibling apps that this app probes or links
# to. Fall back to their NEXT_PUBLIC_* equivalents when unset.
CORE_APP_URL=https://status.example.com
MAIL_APP_URL=https://mail.example.com
STORAGE_APP_URL=https://storage.example.com

# OPTIONAL — CDN base URL used for the CDN service health probe.
CDN_API_URL=https://cdn.example.com

# -----------------------------------------------------------------------------
# Restart integration (optional — graceful; skip when unset)
# -----------------------------------------------------------------------------

# OPTIONAL — deployment platform app identifiers used by the admin auto-restart
# action. Leave empty if you do not wire an auto-restart target.
COOLIFY_APP_UUID=
COOLIFY_MAIL_SERVER_UUID=

# -----------------------------------------------------------------------------
# Public (NEXT_PUBLIC_*) — inlined into the client bundle, safe to expose
# -----------------------------------------------------------------------------

# OPTIONAL — client-side root domain counterpart. Default: sentroy.com
NEXT_PUBLIC_ROOT_DOMAIN=sentroy.com

# OPTIONAL — public URLs of this app and siblings (used in client links/board).
NEXT_PUBLIC_STATUS_APP_URL=https://status.example.com
NEXT_PUBLIC_CORE_APP_URL=https://status.example.com
NEXT_PUBLIC_MAIL_APP_URL=https://mail.example.com
NEXT_PUBLIC_STORAGE_APP_URL=https://storage.example.com

# OPTIONAL — Sentroy public API base URL consumed client-side.
NEXT_PUBLIC_SENTROY_API_URL=https://status.example.com

# OPTIONAL — company slug for the platform's own dogfood status page (root
# redirects here, e.g. /p/<slug>).
NEXT_PUBLIC_SENTROY_STATUS_SLUG=sentroy

# OPTIONAL / graceful — Cloudflare Turnstile site key for the subscribe form.
# Leave empty to disable Turnstile (feature degrades gracefully).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# Runtime (usually set by the framework/build — you rarely set these by hand)
# -----------------------------------------------------------------------------

# OPTIONAL — build/runtime metadata. NODE_ENV and NEXT_RUNTIME are managed by
# Next.js; APP_VERSION is stamped at build time.
# NODE_ENV=production
# NEXT_RUNTIME=
# APP_VERSION=
