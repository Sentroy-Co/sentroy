# =============================================================================
# Sentroy downloader (downloader.sentroy.com, port 3008) — env example
# =============================================================================
# Host-keyed media tool site + tools.<root>. Pairs with downloader-worker.

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/sentroy
MONGODB_DATABASE=sentroy

# ── Domain host-keying (REQUIRED) ────────────────────────────────────────────
# The site keys platform/section off the request host (<platform>.<root>,
# tools.<root>). Default sentroy.com.
SENTROY_ROOT_DOMAIN=your-domain.example.com
NEXT_PUBLIC_ROOT_DOMAIN=your-domain.example.com
NEXT_PUBLIC_CORE_APP_URL=

# ── Worker link (REQUIRED) ───────────────────────────────────────────────────
DOWNLOADER_WORKER_URL=http://downloader-worker:3000

# ── Optional (graceful) ──────────────────────────────────────────────────────
SENTROY_ENV_MASTER_KEY=changeme-openssl-rand-base64-32
INTERNAL_API_SECRET=
